<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES" tools:ignore="QueryAllPackagesPermission" />

    <application
        android:name=".MagnumCricketClubApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MagnumCricketClub"
        tools:targetApi="31">
        
        <activity
            android:name=".ui.auth.AuthActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        
        <activity
            android:name=".ui.home.HomeActivity"
            android:exported="false" />
        
        <activity
            android:name=".ui.MainActivity"
            android:exported="false"
            android:parentActivityName=".ui.home.HomeActivity" />
        
        <activity
            android:name=".ui.expense.AddEditExpenseActivity"
            android:exported="false"
            android:parentActivityName=".ui.MainActivity" />
        
        <activity
            android:name=".ui.expense.TransactionsActivity"
            android:exported="false"
            android:parentActivityName=".ui.MainActivity" />
        
        <activity
            android:name=".ui.income.IncomesActivity"
            android:exported="false"
            android:parentActivityName=".ui.home.HomeActivity" />
        
        <activity
            android:name=".ui.expensetype.ExpenseTypesActivity"
            android:exported="false"
            android:parentActivityName=".ui.home.HomeActivity" />
        
        <activity
            android:name=".ui.incometype.IncomeTypesActivity"
            android:exported="false"
            android:parentActivityName=".ui.home.HomeActivity" />
        
        <activity
            android:name=".ui.charts.ChartsActivity"
            android:exported="false"
            android:parentActivityName=".ui.home.HomeActivity" />
        
        <activity
            android:name=".ui.config.ConfigActivity"
            android:exported="false"
            android:parentActivityName=".ui.home.HomeActivity" />
        
        <activity
            android:name=".ui.me.MeActivity"
            android:exported="false"
            android:parentActivityName=".ui.home.HomeActivity" />
        
        <activity
            android:name=".ui.settings.SettingsActivity"
            android:exported="false"
            android:parentActivityName=".ui.me.MeActivity" />
        
        <activity
            android:name=".ui.teamprofile.TeamProfileActivity"
            android:exported="false"
            android:parentActivityName=".ui.MainActivity" />

        <activity
            android:name=".ui.teamprofile.TeamLedgerActivity"
            android:exported="false"
            android:label="Team Ledger"
            android:parentActivityName=".ui.MainActivity" />

    </application>

</manifest>
