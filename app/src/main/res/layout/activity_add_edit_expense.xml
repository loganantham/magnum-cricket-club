<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Entry Type (Income/Expense) -->
        <LinearLayout
            android:id="@+id/entryTypeLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/input_field_background"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:minHeight="64dp"
            android:gravity="top|start"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginBottom="16dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_group"
                android:tint="#757575"
                android:layout_marginEnd="12dp"
                android:layout_gravity="top|start" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="start|top">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Entry Type"
                    android:textSize="14sp"
                    android:textColor="#424242" />

                <TextView
                    android:id="@+id/entryTypeHintTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Select Income or Expense"
                    android:textSize="14sp"
                    android:textColor="#9E9E9E"
                    android:layout_marginTop="4dp" />

                <AutoCompleteTextView
                    android:id="@+id/entryTypeAutoComplete"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none"
                    android:completionThreshold="0"
                    android:background="@android:color/transparent"
                    android:textColor="#212121"
                    android:textSize="14sp"
                    android:paddingTop="4dp"
                    android:paddingBottom="0dp"
                    android:paddingStart="0dp"
                    android:paddingEnd="0dp"
                    android:minHeight="0dp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Type field (Expense Type / Income Type) - Settings style -->
        <LinearLayout
            android:id="@+id/typeInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/input_field_background"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:minHeight="64dp"
            android:gravity="top|start"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginBottom="16dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_group"
                android:tint="#757575"
                android:layout_marginEnd="12dp"
                android:layout_gravity="top|start" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="start|top">

                <TextView
                    android:id="@+id/typeLabelTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/expense_type"
                    android:textSize="14sp"
                    android:textColor="#424242" />

                <TextView
                    android:id="@+id/typeHintTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/select_expense_type"
                    android:textSize="14sp"
                    android:textColor="#9E9E9E"
                    android:layout_marginTop="4dp" />

                <AutoCompleteTextView
                    android:id="@+id/expenseTypeAutoComplete"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:completionThreshold="0"
                    android:background="@android:color/transparent"
                    android:textColor="#212121"
                    android:textSize="14sp"
                    android:paddingTop="4dp"
                    android:paddingBottom="0dp"
                    android:paddingStart="0dp"
                    android:paddingEnd="0dp"
                    android:minHeight="0dp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Date field -->
        <LinearLayout
            android:id="@+id/dateLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/input_field_background"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:minHeight="64dp"
            android:gravity="top|start"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginBottom="16dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_my_calendar"
                android:tint="#757575"
                android:layout_marginEnd="12dp"
                android:layout_gravity="top|start" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="start|top">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/date"
                    android:textSize="14sp"
                    android:textColor="#424242" />

                <TextView
                    android:id="@+id/dateTextView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/select_date"
                    android:textSize="14sp"
                    android:textColor="#212121"
                    android:layout_marginTop="4dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Amount field - Settings style -->
        <LinearLayout
            android:id="@+id/amountLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/input_field_background"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:minHeight="64dp"
            android:gravity="top|start"
            android:layout_marginBottom="16dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_money"
                android:tint="#757575"
                android:layout_marginEnd="12dp"
                android:layout_gravity="top|start" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="start|top">

                <TextView
                    android:id="@+id/amountLabelTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/amount"
                    android:textSize="14sp"
                    android:textColor="#424242" />

                <TextView
                    android:id="@+id/amountHintTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/enter_amount"
                    android:textSize="14sp"
                    android:textColor="#9E9E9E"
                    android:layout_marginTop="4dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingTop="4dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₹ "
                        android:textSize="14sp"
                        android:textColor="#212121" />

                    <EditText
                        android:id="@+id/amountEditText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:inputType="numberDecimal"
                        android:background="@android:color/transparent"
                        android:textColor="#212121"
                        android:textSize="14sp"
                        android:paddingTop="0dp"
                        android:paddingBottom="0dp"
                        android:paddingStart="0dp"
                        android:paddingEnd="0dp"
                        android:minHeight="0dp"
                        android:includeFontPadding="false" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <!-- Description field - Settings style -->
        <LinearLayout
            android:id="@+id/descriptionLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/input_field_background"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:minHeight="64dp"
            android:gravity="top|start"
            android:layout_marginBottom="16dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_edit"
                android:tint="#757575"
                android:layout_marginEnd="12dp"
                android:layout_gravity="top|start" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="start|top">

                <TextView
                    android:id="@+id/descriptionLabelTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/description"
                    android:textSize="14sp"
                    android:textColor="#424242" />

                <TextView
                    android:id="@+id/descriptionHintTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/enter_description"
                    android:textSize="14sp"
                    android:textColor="#9E9E9E"
                    android:layout_marginTop="4dp" />

                <EditText
                    android:id="@+id/descriptionEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textMultiLine"
                    android:maxLines="3"
                    android:background="@android:color/transparent"
                    android:textColor="#212121"
                    android:textSize="14sp"
                    android:paddingTop="4dp"
                    android:paddingBottom="0dp"
                    android:paddingStart="0dp"
                    android:paddingEnd="0dp"
                    android:minHeight="0dp"
                    android:includeFontPadding="false" />

            </LinearLayout>

        </LinearLayout>

        <CheckBox
            android:id="@+id/shareWhatsAppCheckBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/share_via_whatsapp"
            android:textSize="14sp"
            android:textColor="#424242"
            android:layout_marginBottom="16dp"
            android:checked="true" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/saveButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/save"
            android:layout_marginTop="16dp"
            app:backgroundTint="@color/primary_color" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/deleteButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/delete"
            android:visibility="gone"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_marginTop="8dp" />

    </LinearLayout>

</ScrollView>
