<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    tools:context=".ui.settings.SettingsActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:theme="@style/Theme.MagnumExpenses.AppBarOverlay">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="?attr/colorPrimary"
            app:popupTheme="@style/Theme.MagnumExpenses.PopupOverlay" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:padding="16dp"
        android:paddingBottom="100dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- WhatsApp Settings Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/card_background"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- WhatsApp Settings Title -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/whatsapp_settings"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="16dp" />

                    <!-- WhatsApp Group ID Input -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:background="@drawable/input_field_background"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingTop="12dp"
                        android:paddingBottom="12dp"
                        android:minHeight="64dp"
                        android:gravity="top|start"
                        android:layout_marginBottom="16dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_share"
                            android:tint="#757575"
                            android:layout_marginEnd="12dp"
                            android:layout_gravity="top|start"
                            android:layout_marginTop="0dp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="start|top"
                            android:baselineAligned="false">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/whatsapp_group_id"
                                android:textSize="14sp"
                                android:textColor="#424242"
                                android:textStyle="normal" />

                            <Space
                                android:id="@+id/whatsappSpacer"
                                android:layout_width="match_parent"
                                android:layout_height="28dp" />

                            <TextView
                                android:id="@+id/whatsappHintTextView"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/whatsapp_group_id_hint"
                                android:textSize="14sp"
                                android:textColor="#9E9E9E" />

                            <EditText
                                android:id="@+id/whatsappGroupIdEditText"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="text"
                                android:background="@android:color/transparent"
                                android:textColor="#212121"
                                android:textSize="14sp"
                                android:paddingTop="0dp"
                                android:paddingBottom="0dp"
                                android:paddingStart="0dp"
                                android:paddingEnd="0dp"
                                android:minHeight="0dp"
                                android:singleLine="true"
                                android:includeFontPadding="false"
                                android:lines="1"
                                android:maxLines="1"
                                android:hint=""
                                android:visibility="gone" />

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Enable WhatsApp Notifications Toggle -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingTop="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/whatsapp_enabled"
                            android:textSize="16sp"
                            android:textColor="@color/text_primary" />

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/whatsappNotificationsSwitch"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Team Settings Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/card_background"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Team Settings Title -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/team_settings"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="16dp" />

                    <!-- Team Name Input -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:background="@drawable/input_field_background"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingTop="12dp"
                        android:paddingBottom="12dp"
                        android:minHeight="64dp"
                        android:gravity="top|start">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_group"
                            android:tint="#757575"
                            android:layout_marginEnd="12dp"
                            android:layout_gravity="top|start"
                            android:layout_marginTop="0dp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="start|top"
                            android:baselineAligned="false">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/team_name"
                                android:textSize="14sp"
                                android:textColor="#424242"
                                android:textStyle="normal" />

                            <Space
                                android:id="@+id/teamSpacer"
                                android:layout_width="match_parent"
                                android:layout_height="28dp" />

                            <TextView
                                android:id="@+id/teamHintTextView"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/team_name_hint"
                                android:textSize="14sp"
                                android:textColor="#9E9E9E" />

                            <EditText
                                android:id="@+id/teamNameEditText"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="text"
                                android:background="@android:color/transparent"
                                android:textColor="#212121"
                                android:textSize="14sp"
                                android:paddingTop="0dp"
                                android:paddingBottom="0dp"
                                android:paddingStart="0dp"
                                android:paddingEnd="0dp"
                                android:minHeight="0dp"
                                android:singleLine="true"
                                android:includeFontPadding="false"
                                android:lines="1"
                                android:maxLines="1"
                                android:hint=""
                                android:visibility="gone" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- App Restrictions Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/card_background"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="App Restrictions"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="16dp" />

                    <!-- Domain Restriction Input -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:background="@drawable/input_field_background"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingTop="12dp"
                        android:paddingBottom="12dp"
                        android:minHeight="64dp"
                        android:gravity="top|start">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_share"
                            android:tint="#757575"
                            android:layout_marginEnd="12dp"
                            android:layout_gravity="top|start"
                            android:layout_marginTop="0dp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="start|top"
                            android:baselineAligned="false">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Allowed Signup Domain"
                                android:textSize="14sp"
                                android:textColor="#424242"
                                android:textStyle="normal" />

                            <Space
                                android:id="@+id/domainSpacer"
                                android:layout_width="match_parent"
                                android:layout_height="28dp" />

                            <TextView
                                android:id="@+id/domainHintTextView"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="e.g. magnum.cricket.club"
                                android:textSize="14sp"
                                android:textColor="#9E9E9E" />

                            <EditText
                                android:id="@+id/allowedDomainEditText"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textUri"
                                android:background="@android:color/transparent"
                                android:textColor="#212121"
                                android:textSize="14sp"
                                android:paddingTop="0dp"
                                android:paddingBottom="0dp"
                                android:paddingStart="0dp"
                                android:paddingEnd="0dp"
                                android:minHeight="0dp"
                                android:singleLine="true"
                                android:includeFontPadding="false"
                                android:lines="1"
                                android:maxLines="1"
                                android:hint=""
                                android:visibility="gone" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- SAVE Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/saveButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:text="@string/save"
        android:textAllCaps="true"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:backgroundTint="@color/primary_color"
        android:paddingTop="16dp"
        android:paddingBottom="16dp"
        app:cornerRadius="8dp"
        app:elevation="4dp" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
